# roles/wireguard-server/templates/server.conf.j2
[Interface]
    Address = {{ wireguard_ip }}/24
    ListenPort = {{ wireguard_listen_port }}
    PrivateKey = {{ wireguard_private_key }}

{% for client in vpn_peers %}
[Peer]
    PublicKey = {{ hostvars[client]['wireguard_public_key'] }}
    AllowedIPs = {{ hostvars[client]['wireguard_ip'] }}/32
    PersistentKeepalive = 20
{% endfor %}