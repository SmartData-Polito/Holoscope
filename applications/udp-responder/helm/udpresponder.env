VERSION="0.3"

# ClickHouse (optional)
DATABASE_HOST="127.0.0.1"
DATABASE_PORT="9000"
DATABASE="test"
DATABASE_USER="test"
DATABASE_PASSWORD="test"
DATABASE_CLIENT_NAME="udpspoofer-client"

# Channel buffer size for packet channels (TCP/UDP database queues and outbound traffic)
CHANNEL_SIZE="100000"

# ClickHouse insert batch size for TCP and UDP
TCP_PASSIVE_INSERT_BATCH_SIZE="5000"
TCP_REACTIVE_INSERT_BATCH_SIZE="50000"
UDP_PASSIVE_INSERT_BATCH_SIZE="5000"
UDP_REACTIVE_INSERT_BATCH_SIZE="25000"

# Packet Rate limits per different Entries (Source IP, Source /24, Endpoint (dst_ip, dst_port))
# Defaults based on UDP traffic baselines observed
UDP_IP_LIMIT="300"
UDP_SUBNET_LIMIT="900"
UDP_ENDPOINT_LIMIT="1000"

# Time window within which packet rates are applied. Increase at your own risk
UDP_RL_WINDOW_MINUTES="1"

# Blocking time applied on passing an Entry rate within UDP_RL_WINDOW_MINUTES
UDP_RL_BLOCK_TTL_MINUTES="60"

# Interval in minutes to check for entries to unblock
UDP_RL_CLEANUP_INTERVAL_MINUTES="10"

# Every N cleanup ticks, also prune expired rate entries (ipRates/subRates/epRates)
# Cleanup frequency: UDP_RL_CLEANUP_INTERVAL_MINUTES * UDP_ENTRY_CLEANUP_INTERVALS
UDP_ENTRY_CLEANUP_INTERVALS="12"

LOG_LEVEL="info"
# Interval in seconds to log potential packet drops by database channels
STATIC_DROP_LOG_SECS="30"